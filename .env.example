# Chat Provider, remember to set the api key / base url / model for the provider
CHAT_PROVIDER=deepseek

# Embeddings Provider, remember to set the api key / base url / model for the provider
# Note: DeepSeek does not provide an embedding API; use ollama, openai, or huggingface
EMBEDDINGS_PROVIDER=ollama

# OpenAI settings (required if CHAT_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDINGS_MODEL=text-embedding-ada-002

# Deepseek settings (required if CHAT_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
# Deepseek model could be deepseek-chat or deepseek-reasoner
DEEPSEEK_MODEL=deepseek-v4-flash

# Ollama settings (required if CHAT_PROVIDER=ollama, in docker compose, use host.docker.internal instead of localhost)

# If you are using macOS with docker-compose, you can use host.docker.internal
OLLAMA_API_BASE=http://host.docker.internal:11434

# If you used a compiled installation, you can use http://localhost:11434
# OLLAMA_API_BASE=http://localhost:11434

# If you are a Linux server using docker-compose, you need to use the host machine's IP address.
# OLLAMA_API_BASE=http://172.17.0.1:11434

OLLAMA_MODEL=deepseek-r1:7b
# Ollama Embedding Model (required if EMBEDDINGS_PROVIDER=ollama)
# Supported models (pick one; run `ollama pull <name>` first):
#   bge-m3            - 1024 dims, multilingual, better quality (~1.2GB) [default]
#   nomic-embed-text  - 768 dims, lightweight and fast (~274MB)
# Switching models requires re-processing documents (vector dimensions differ).
OLLAMA_EMBEDDINGS_MODEL=bge-m3
# OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text

# HuggingFace settings (required if EMBEDDINGS_PROVIDER=huggingface)
# HuggingFace API key is optional - only needed for gated models or API usage
HUGGINGFACE_API_KEY=
# HuggingFace Embedding Model (default: sentence-transformers/all-MiniLM-L6-v2)
# Popular options:
#   - sentence-transformers/all-MiniLM-L6-v2 (lightweight, fast)
#   - sentence-transformers/all-mpnet-base-v2 (better quality)
#   - BAAI/bge-small-en-v1.5 (good balance)
#   - BAAI/bge-large-en-v1.5 (high quality)
HUGGINGFACE_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# DashScope settings (optional - required only if using DashScope)
DASH_SCOPE_API_KEY=
DASH_SCOPE_EMBEDDINGS_MODEL=

# MiniMax settings (required if CHAT_PROVIDER=minimax)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_API_BASE=https://api.minimax.io/v1
# MiniMax model could be MiniMax-M2.7 or MiniMax-M2.7-highspeed
MINIMAX_MODEL=MiniMax-M2.7

# MinIO settings (required)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents

# Vector Store settings (required)
VECTOR_STORE_TYPE=chroma

# Chroma DB settings (required if VECTOR_STORE_TYPE=chroma)
# Local dev (no Docker): persistent mode, data under ./chroma_data
# CHROMA_MODE=persistent
# CHROMA_PERSIST_DIRECTORY=./chroma_data
# Docker Compose: HTTP mode
CHROMA_MODE=http
CHROMA_DB_HOST=chromadb
CHROMA_DB_PORT=8000

# Qdrant DB settings (optional - required only if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_PREFER_GRPC=true

# PostgreSQL settings (required)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=ragwebui
POSTGRES_PASSWORD=ragwebui
POSTGRES_DATABASE=ragwebui

# JWT settings (required)
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Timezone settings (optional)
TZ=Asia/Shanghai
