# Copy to .env for local dev (pnpm dev), or to .env.production for ./deploy.sh
#
# Production (Docker backend on VPS): use host.docker.internal for host services
#   POSTGRES_SERVER=host.docker.internal
#   MINIO_ENDPOINT=host.docker.internal:9000
#   CHROMA_URL=http://host.docker.internal:28100
#   EMBEDDINGS_API_BASE=http://host.docker.internal:11434
#   API_BASE_URL=https://api.example.com
#   WEB_BASE_URL=https://app.example.com

# =============================================================================
# Chat LLM — set CHAT_PROVIDER, then CHAT_API_KEY / CHAT_API_BASE / CHAT_MODEL
# =============================================================================
# CHAT_PROVIDER (via .env, set matching CHAT_API_* below):
#   Native: openai | deepseek | minimax | ollama
#   OpenAI-compatible API (CHAT_API_BASE = provider's /v1 URL):
#     anthropic | google | qwen | kimi | mistral | azure | zhipu
# Additional providers can also be added in Dashboard → Model settings (DB).
#
# CHAT_API_KEY: required for openai, deepseek, minimax; omit for ollama
# CHAT_API_BASE: API base URL (ollama: e.g. http://localhost:11434)
# CHAT_MODEL: model id for the selected provider
CHAT_PROVIDER=deepseek
CHAT_API_KEY=your-api-key-here
CHAT_API_BASE=https://api.deepseek.com
CHAT_MODEL=deepseek-v4-flash

# =============================================================================
# Embeddings — set EMBEDDINGS_PROVIDER, then EMBEDDINGS_API_* / EMBEDDINGS_MODEL
# =============================================================================
# EMBEDDINGS_PROVIDER:
#   openai | ollama | dashscope | huggingface
#
# EMBEDDINGS_API_KEY: required for openai, dashscope; optional for huggingface; omit for ollama
# EMBEDDINGS_API_BASE: required for ollama (e.g. http://localhost:11434); optional for openai
# EMBEDDINGS_MODEL: embedding model id (see notes below for ollama options)
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_API_BASE=http://localhost:11434
EMBEDDINGS_MODEL=bge-m3

# Ollama EMBEDDINGS_MODEL options (run `ollama pull <name>` first):
#   bge-m3            - 1024 dims, multilingual (~1.2GB)
#   nomic-embed-text  - 768 dims, lightweight (~274MB)
# Changing model requires re-processing documents (vector dimensions differ).

# Legacy per-provider vars (optional fallback when CHAT_* / EMBEDDINGS_* are empty)
# DEEPSEEK_API_KEY=  DEEPSEEK_API_BASE=  DEEPSEEK_MODEL=
# OPENAI_API_KEY=  OPENAI_API_BASE=  OPENAI_MODEL=  OPENAI_EMBEDDINGS_MODEL=
# OLLAMA_API_BASE=  OLLAMA_EMBEDDINGS_MODEL=
# MINIMAX_API_KEY=  MINIMAX_API_BASE=  MINIMAX_MODEL=
# DASH_SCOPE_API_KEY=  DASH_SCOPE_EMBEDDINGS_MODEL=
# HUGGINGFACE_API_KEY=  HUGGINGFACE_EMBEDDINGS_MODEL=

# =============================================================================
# MinIO (required)
# =============================================================================
# Docker Compose: minio:9000. Host dev (pnpm dev): localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents

# =============================================================================
# Vector store (required)
# =============================================================================
VECTOR_STORE_TYPE=chroma

# Chroma HTTP (VECTOR_STORE_TYPE=chroma)
# pnpm dev on host: http://127.0.0.1:28100 (prefer 127.0.0.1 over localhost on macOS)
CHROMA_URL=http://127.0.0.1:28100
# docker compose API in container: http://chromadb:8000
# production backend in Docker: http://host.docker.internal:28100
# DOCUMENT_PROCESSING_CONCURRENCY=1

# Qdrant (VECTOR_STORE_TYPE=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_PREFER_GRPC=true

# =============================================================================
# PostgreSQL (required)
# =============================================================================
# Compose: db. Host dev: localhost (apps/api/scripts/dev.sh may set when unset)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=ragwebui
POSTGRES_PASSWORD=ragwebui
POSTGRES_DATABASE=ragwebui

# =============================================================================
# JWT (required)
# =============================================================================
# Use a long random string in production (never keep the default below).
SECRET_KEY=your-secret-key-here
# Default 10080 = 7 days. For production consider 1440 (24h) or shorter.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =============================================================================
# Production URLs (optional; docker-compose.prod)
# =============================================================================
# API_BASE_URL=https://api.example.com
# WEB_BASE_URL=https://app.example.com
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# Misc
# =============================================================================
TZ=Asia/Shanghai
