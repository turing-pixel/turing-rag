    "rag": {
      "title": "RAG Pipeline",
      "description": "Interactive view of how documents are ingested, indexed, retrieved, and turned into grounded answers in the backend.",
      "legendTitle": "Node types",
      "summariesTitle": "Pipeline overview",
      "diagramAria": "RAG backend pipeline diagram",
      "minimapAria": "Pipeline minimap",
      "toolbar": {
        "aria": "Flow diagram tools",
        "autoLayoutVertical": "Auto layout (vertical)",
        "autoLayoutHorizontal": "Auto layout (horizontal)",
        "resetLayout": "Reset to default layout",
        "fitView": "Fit to view",
        "dragHint": "Drag any step to reposition. Steps are grouped by swimlane."
      },
      "edges": {
        "kbCollection": "kb_ID"
      },
      "legend": {
        "api": "HTTP API",
        "service": "Background service",
        "storage": "Storage",
        "optional": "Optional step"
      },
      "lanes": {
        "ingestion": "Document ingestion",
        "chat": "Chat / RAG answer",
        "retrieval": "Retrieval only"
      },
      "summaries": {
        "ingestion": "Upload files, optionally preview chunks, then process in the background: split text, embed, and store in MinIO, PostgreSQL, and Chroma or Qdrant.",
        "chat": "User messages trigger LangChain history-aware retrieval over kb_ID collections, then a stuff-documents chain streams the LLM reply with citations.",
        "retrieval": "Test retrieval and the Open API query endpoint run similarity search without calling the LLM."
      },
      "steps": {
        "upload": {
          "title": "Upload",
          "subtitle": "POST .../documents/upload",
          "detail": "SHA-256 dedup, temp file under /tmp/rag_uploads"
        },
        "preview": {
          "title": "Preview chunks",
          "subtitle": "POST .../documents/preview",
          "detail": "LangChain loaders + RecursiveCharacterTextSplitter; no DB write"
        },
        "process": {
          "title": "Enqueue processing",
          "subtitle": "POST .../documents/process",
          "detail": "Creates ProcessingTask; asyncio background task"
        },
        "pollTasks": {
          "title": "Poll task status",
          "subtitle": "GET .../documents/tasks",
          "detail": "Frontend polls until completed or failed"
        },
        "loadSplit": {
          "title": "Load and split",
          "subtitle": "process_document_background",
          "detail": "PDF, DOCX, MD, TXT via LangChain loaders"
        },
        "embeddings": {
          "title": "Embeddings",
          "subtitle": "EmbeddingsFactory.create",
          "detail": "openai | dashscope | ollama | huggingface"
        },
        "vectorStore": {
          "title": "Vector store",
          "subtitle": "VectorStoreFactory.create",
          "detail": "Collection kb_ID (prefix kb_ + knowledge base id); Chroma or Qdrant"
        },
        "persist": {
          "title": "Persist and index",
          "subtitle": "add_documents + MinIO + DB",
          "detail": "Document, DocumentChunk, permanent object storage"
        },
        "userMessage": {
          "title": "User message",
          "subtitle": "POST /api/chat/:chat_uuid/messages",
          "detail": "SSE stream via generate_response"
        },
        "resolveLlm": {
          "title": "Resolve LLM",
          "subtitle": "LLMFactory.create",
          "detail": "User LLM config from llm_config_service"
        },
        "retriever": {
          "title": "History-aware retriever",
          "subtitle": "create_history_aware_retriever",
          "detail": "Reformulates question with chat history"
        },
        "ragChain": {
          "title": "RAG chain",
          "subtitle": "create_retrieval_chain",
          "detail": "stuff_documents_chain + retrieved context"
        },
        "stream": {
          "title": "Stream answer",
          "subtitle": "rag_chain.astream",
          "detail": "Base64 context chunks + citation markdown"
        },
        "testRetrieval": {
          "title": "Test retrieval",
          "subtitle": "POST .../test-retrieval",
          "detail": "similarity_search_with_score; no LLM"
        }
      }
    },
