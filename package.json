{
  "name": "rag-web-ui",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev": "sh scripts/dev-chroma.sh && turbo dev",
    "dev:chroma": "sh scripts/dev-chroma.sh",
    "dev:chroma:stop": "sh scripts/dev-chroma-stop.sh",
    "dev:app": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:ci": "turbo test:ci",
    "reset-data": "pnpm --filter @rag-web-ui/api reset-data",
    "reset-data:dry-run": "pnpm --filter @rag-web-ui/api reset-data:dry-run"
  },
  "devDependencies": {
    "turbo": "^2.9.0"
  }
}
