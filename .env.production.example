# Copy to .env.production and fill in secrets before ./deploy.sh
# Docker prod: backend reaches host services via host.docker.internal

CHAT_PROVIDER=deepseek
EMBEDDINGS_PROVIDER=ollama

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_EMBEDDINGS_MODEL=bge-m3

MINIO_ENDPOINT=host.docker.internal:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=documents

VECTOR_STORE_TYPE=chroma
CHROMA_MODE=persistent
CHROMA_PERSIST_DIRECTORY=/data/chroma

POSTGRES_SERVER=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DATABASE=rag_ui

SECRET_KEY=your-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Browser -> backend URL (IP or domain). deploy.sh auto-detects when empty.
NEXT_PUBLIC_API_URL=

TZ=Asia/Shanghai
